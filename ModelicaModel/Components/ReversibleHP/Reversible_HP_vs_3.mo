within HeatPumpModel.Components.ReversibleHP;
model Reversible_HP_vs_3 "Reversible HP with one single thermodynamic cycle and switch operation"

   //---------------Components---------------------------------------------------------------------------------------------------------------------------------------------------------------------

  Ref_cycle_reversible_vs_1 ref_cycle_reversible_vs_1_1(
    fileName=fileName,
    SH=SH,
    SBC=SBC,
    redeclare package Medium = Medium,
    F=F,
    PP_eva=PP_HE2,
    PP_cond=PP_HE1) annotation (Placement(transformation(extent={{26,-14},{60,20}})));
  PlateHE_vs_1 PHE(
    redeclare package Medium = HE1_medium,
    m_flow_nominal = m_flow_nominal,
    m_f_nom_H=m_flow_HE1_nominal_H,
    m_f_nom_C=m_flow_HE1_nominal_C,
    dp_nominal=dp_HE1_nominal,
    m_ref_nom_C =m_ref_nom_C,
    m_ref_nom_H =m_ref_nom_H,
    UA_value_PHE = UA_value_HE1,
    UA_nom_heat=UA_nom_heat_HE1,
    UA_nom_cool=UA_nom_cool_HE1,
    fileNameH=fileName_H,
    fileNameC = fileName_C,
    V=V_HE1,
    Tau_cost_PHE = Tau_cost_HE1) annotation (Placement(transformation(extent={{28,58},{58,88}})));
  FinCoil_vs_1 FinCoil(
    redeclare package Medium = HE2_medium,
    m_flow_nominal=m_flow_HE2_nominal,
    dp_nominal=dp_HE2_nominal,
    UA_value_FC = UA_value_HE2,
    UA_nom_heat = UA_nom_heat_HE2,
    UA_nom_cool = UA_nom_cool_HE2,
    V=V_HE2,
     Tau_cost_FC = Tau_cost_HE2) annotation (Placement(transformation(extent={{34,-56},{64,-86}})));

  Control_vs_3 control_vs_3(Tset=Tset,
    DeltaTup=DeltaTup,
    DeltaTlow=DeltaTlow,
    controllerType_heat=controllerType_heat,
    k_heat=k_heat,
    Ti_heat=Ti_heat,
    Td_heating=Td_heating,
    controllerType_cool=controllerType_cool,
    k_cool=k_cool,
    Ti_cool=Ti_cool,
    Td_cool=Td_cool,
    f_nominal=f_nominal,
    Tdelay = Tdelay) annotation (Placement(transformation(extent={{-94,-10},{-74,10}})));

  CMP_reversible_vs_1 CMP_reversible(
    fileName=fileName,
    CMP_type=CMP_type,
    minF=minF) annotation (Placement(transformation(extent={{-50,-10},{-24,16}})));
  Modelica.Fluid.Sensors.Temperature TsourceIn(redeclare package Medium = HE2_medium) annotation (Placement(transformation(extent={{0,-54},{20,-34}})));
  Modelica.Fluid.Sensors.Temperature TloadIn(redeclare package Medium = HE1_medium) annotation (Placement(transformation(extent={{-2,32},{18,52}})));

  Modelica.Fluid.Sensors.TemperatureTwoPort TsourceOut( redeclare package Medium = HE2_medium) annotation (Placement(transformation(extent={{72,-62},{92,-82}})));
  Modelica.Fluid.Sensors.TemperatureTwoPort TloadOut( redeclare package Medium = HE1_medium) annotation (Placement(transformation(extent={{76,64},{96,84}})));

  //---------------Interfaces blocks---------------------------------------------------------------------------------------------------------------------------------------------------------------

  Modelica.Fluid.Interfaces.FluidPort_a Load_in(redeclare package Medium = HE1_medium) "Fluid connector a (positive design flow direction is from port_a to port_b)" annotation (Placement(transformation(extent={{-120,62},
            {-100,82}}),                                                                                                                                                                                                        iconTransformation(extent={{-120,62},
            {-100,82}})));
  Modelica.Fluid.Interfaces.FluidPort_b Load_out(redeclare package Medium = HE1_medium) "Fluid connector b (positive design flow direction is from port_a to port_b)" annotation (Placement(transformation(extent={{100,64},
            {120,84}}),                                                                                                                                                                                                        iconTransformation(extent={{100,64},
            {120,84}})));
  Modelica.Fluid.Interfaces.FluidPort_a Source_in(redeclare package Medium = HE2_medium) "Fluid connector a (positive design flow direction is from port_a to port_b)" annotation (Placement(transformation(extent={{-120,
            -80},{-100,-60}}),                                                                                                                                                                                                        iconTransformation(extent={{-120,
            -80},{-100,-60}})));
  Modelica.Fluid.Interfaces.FluidPort_b Source_out(redeclare package Medium = HE2_medium) "Fluid connector b (positive design flow direction is from port_a to port_b)" annotation (Placement(transformation(extent={{100,-82},
            {120,-62}}),                                                                                                                                                                                                        iconTransformation(extent={{100,-82},
            {120,-62}})));
  Modelica.Blocks.Interfaces.RealOutput Wel_ref "heating capacity calculated with refrigerant cycle" annotation (Placement(transformation(extent={{100,-10},{120,10}}),iconTransformation(extent={{100,-10},
            {120,10}})));
  Modelica.Blocks.Interfaces.RealOutput Efficency "Coefficient of performance" annotation (Placement(transformation(extent={{100,-50},{120,-30}}),iconTransformation(extent={{100,-50},{120,-30}})));
  Modelica.Blocks.Math.Division division annotation (Placement(transformation(extent={{80,34},{94,48}})));
  Modelica.Blocks.Interfaces.RealOutput Efficency_System "System_Efficency" annotation (Placement(transformation(extent={{106,32},{126,52}}), iconTransformation(extent={{100,30},{120,50}})));
   Modelica.Blocks.Interfaces.RealInput Tmeas1 annotation (Placement(transformation(extent={{-132,-8},{-116,8}}), iconTransformation(extent={{-132,-8},{-116,8}})));
  //---------------Medium Replaceble Packages-----------------------------------------------------------------------------------------------------------------------------------------------------

  replaceable package Medium = ExternalMedia.Media.CoolPropMedium (mediumName="R410a", substanceNames={"R410a"}) annotation (choices(
      choice(redeclare package Medium = ExternalMedia.Media.CoolPropMedium (mediumName="R290", substanceNames={"R290"}) "R290"),
      choice(redeclare package Medium = ExternalMedia.Media.CoolPropMedium (mediumName="R32", substanceNames={"R32"}) "R32"),
      choice(redeclare package Medium = ExternalMedia.Media.CoolPropMedium (mediumName="R410A", substanceNames={"R410A"}) "R410A")), Dialog(group="Refrigerant"));
  replaceable package HE1_medium = Modelica.Media.Interfaces.PartialMedium annotation (choicesAllMatching=true, Dialog(group="HE1"));
  replaceable package HE2_medium = Modelica.Media.Interfaces.PartialMedium annotation (choicesAllMatching=true, Dialog(group="HE2"));

  //-------------Input Parameters Refrigerant Cycle------------------------------------------------------------------------------------------------------------------------------------------------

  parameter Real SH(unit="K") "superheat" annotation (Dialog(group="Refrigerant"));
  parameter Real SBC(unit="K") "subcooling" annotation (Dialog(group="Refrigerant"));
  //-------------Input Parameters CMP-------------------------------------------------------------------------------------------------------------------------------------------------------------

  parameter Real F "Dabiri Correlation parameter" annotation (Dialog(group="CMP"));
  parameter String fileName="Select a compressor model" "File path where polynomial coefficients are stored" annotation (choices(
      choice="C:/Users/benafra10167/Desktop/CMP_polynomial/Fixed_Speed_Danfoss/HRH054U4 polynomials.xlsx",
      choice="C:/Users/benafra10167/Desktop/CMP_polynomial/Variable_Speed_Danfoss/VRJ028-K polynomials.xlsx",
      choice="C:/Users/benafra10167/Desktop/CMP_polynomial/Variable_Speed_Danfoss/VZH028CH polynomials.xlsx",
      choice="C:/Users/benafra10167/Desktop/CMP_polynomial/Variable_Speed_Copeland/XHV0181P-9E9-ED3015A polynomials.xlsx"), Dialog(group="CMP"));
  parameter String CMP_type="Fixed speed" annotation (choices(
      choice="Fixed speed",
      choice="Variable speed 20 coeff",
      choice="Variable speed 30 coeff"), Dialog(group="CMP"));
  parameter Real minF( unit = "Hz") "minimum compressor frequency" annotation (Dialog(group="CMP"));

  //-------------Input Parameters HE1--------------------------------------------------------------------------------------------------------------------------------------------------------

  parameter Modelica.Units.SI.MassFlowRate m_flow_nominal "Nominal mass flow rate. If the HP works mainyl in H mode, use heating, else cooling" annotation (Dialog(group="HE1"));
  parameter Modelica.Units.SI.MassFlowRate m_flow_HE1_nominal_H "Nominal mass flow rate heating" annotation (Dialog(group="HE1"));
  parameter Modelica.Units.SI.MassFlowRate m_flow_HE1_nominal_C "Nominal mass flow rate cooling" annotation (Dialog(group="HE1"));
  parameter Real m_ref_nom_H(unit="kg/s") "Nominal refrigerant mass flow rate [kg/s] heaing" annotation (Dialog(group="HE1"));
  parameter Real m_ref_nom_C(unit="kg/s") "Nominal refrigerant mass flow rate [kg/s] cooling" annotation (Dialog(group="HE1"));
  parameter Modelica.Units.SI.PressureDifference dp_HE1_nominal "Pressure difference" annotation (Dialog(group="HE1"));
  parameter Real PP_HE1(unit="K") = 2 "Condenser pinch point" annotation (Dialog(group="HE1"));
  parameter Real UA_nom_heat_HE1(unit="W/K") "Nominal UA value" annotation (Dialog(group="HE1"));
  parameter Real UA_nom_cool_HE1(unit="W/K") "Nominal UA value" annotation (Dialog(group="HE1"));
  parameter Modelica.Units.SI.Volume V_HE1 "Volume" annotation (Dialog(group="HE1"));
  parameter Modelica.Units.SI.Time Tau_cost_HE1(displayUnit="min")  "Time Constant of Cond Filter" annotation (Dialog(group="HE1"));
  parameter String UA_value_HE1="Select how to calculate UA" annotation (choices(choice="Nominal value", choice="Parametric correlation"), Dialog(group="HE1"));
  parameter String fileName_HE1_H="C:/Users\benafra10167/Desktop/HE_polynomial/B8T.xlsx" "File path where polynomial coefficients are stored" annotation (choices(
      choice="C:/Users/benafra10167/Desktop/HE_polynomial/B8T.xlsx",
      choice="C:/Users/benafra10167/Desktop/HE_polynomial/B10T.xlsx",
      choice="C:/Users/benafra10167/Desktop/HE_polynomial/B8LAS.xlsx",
      choice="C:/Users/benafra10167/Desktop/HE_polynomial/B16.xlsx"), Dialog(group="HE1"));
  parameter String fileName_HE1_C="C:/Users\benafra10167/Desktop/HE_polynomial/B8T.xlsx" "File path where polynomial coefficients are stored" annotation (choices(
      choice="C:/Users/benafra10167/Desktop/HE_polynomial/B16_cooling.xlsx"), Dialog(group="HE1"));
  //-------------Input Parameters HE2-------------------------------------------------------------------------------------------------------------------------------------------------------

  parameter Modelica.Units.SI.MassFlowRate m_flow_HE2_nominal "Nominal mass flow rate" annotation (Dialog(group="HE2"));
  parameter Modelica.Units.SI.PressureDifference dp_HE2_nominal "Pressure difference" annotation (Dialog(group="HE2"));
  parameter Real PP_HE2(unit="K")  "Evaporator pinch point" annotation (Dialog(group="HE2"));
  parameter Real UA_nom_heat_HE2(unit="W/K") "Heat transfer/ area product" annotation (Dialog(group="HE2"));
  parameter Real UA_nom_cool_HE2(unit="W/K") "Nominal UA value" annotation (Dialog(group="HE2"));
  parameter Modelica.Units.SI.Volume V_HE2 "Volume" annotation (Dialog(group="HE2"));
  parameter Modelica.Units.SI.Time Tau_cost_HE2(displayUnit="min") "Time Constant of Eva Filter" annotation (Dialog(group="HE2"));
  parameter String UA_value_HE2="Select how to calculate UA" annotation (choices(choice="Nominal value", choice="Parametric correlation"), Dialog(group="HE2"));


  //------------------------------------Control parameters ----------------------------------------------------------------------------------------------------------------------------------------
  parameter String HP_main_operation="Select the main HP operation mode"  annotation (choices(
      choice="Heating Mode",
      choice="Cooling Mode"), Dialog(group="Control"));
  parameter Real Tset( unit = "K")
                                  "set point temperature" annotation (Dialog(group="Control"));
  parameter Real DeltaTup( unit = "K") "upper temperature dead band" annotation (Dialog(group="Control"));
  parameter Real DeltaTlow( unit = "K") "lower temperature dead band" annotation (Dialog(group="Control"));
  parameter Modelica.Blocks.Types.SimpleController controllerType_heat=Modelica.Blocks.Types.SimpleController.PI "Type of controller" annotation (Dialog(group="Control"));
  parameter Real k_heat=1 "Gain of controller" annotation (Dialog(group="Control"));
  parameter Modelica.Units.SI.Time Ti_heat=0.5 "Time constant of Integrator block" annotation (Dialog(group="Control"));
  parameter Modelica.Units.SI.Time Td_heating=0.1 "Time constant of Derivative block" annotation (Dialog(group="Control"));
  parameter Modelica.Blocks.Types.SimpleController controllerType_cool=Modelica.Blocks.Types.SimpleController.PI "Type of controller" annotation (Dialog(group="Control"));
  parameter Real k_cool=1 "Gain of controller" annotation (Dialog(group="Control"));
  parameter Modelica.Units.SI.Time Ti_cool=0.5 "Time constant of Integrator block" annotation (Dialog(group="Control"));
  parameter Modelica.Units.SI.Time Td_cool=0.1 "Time constant of Derivative block" annotation (Dialog(group="Control"));
  parameter Real f_nominal( unit = "Hz")
                                        "nominal compressor frequency" annotation (Dialog(group="CMP"));
  parameter Real Tdelay( unit = "s") "time dealy of compressor turning ON"
                                                                          annotation (Dialog(group="Control"));

  record box
    Modelica.Units.SI.Pressure Pcond "Total condensing pressure";
    Modelica.Units.SI.Pressure Peva "Total evaporation pressure";
    Modelica.Units.SI.Temperature Tcond "Total condensing temperature";
    Modelica.Units.SI.Temperature Teva "Total evaporation temperature";
    Modelica.Units.SI.Temperature TloadIn "Load inlet temperature";
    Modelica.Units.SI.Temperature TloadOut "Load outlet temperature";
    Modelica.Units.SI.Temperature TsourceIn "Source inlet temperature";
    Modelica.Units.SI.Temperature TsourceOut "Source outlet temperature";
    Real Wel( unit =" W") "Total electrical power";
    Real HC( unit = "W") "Total heating capacity";
    Real CC( unit = "W") "Total cooling capacity";
    Real CMP_f( unit = "Hz") "Compressor frequency";
    Integer HP_target "Operation target mode of HP";
    Integer HP_mode "Operation mode of HP";

  end box;

  box Output;

equation

   Output.Pcond = ref_cycle_reversible_vs_1_1.Pcond;
   Output.Peva = ref_cycle_reversible_vs_1_1.Peva;
   Output.Tcond = ref_cycle_reversible_vs_1_1.Tcond;
   Output.Teva = ref_cycle_reversible_vs_1_1.Teva;
   Output.TloadIn = TloadIn.T;
   Output.TloadOut = TloadOut.T;
   Output.TsourceIn = TsourceIn.T;
   Output.TsourceOut = TsourceOut.T;
   Output.Wel = ref_cycle_reversible_vs_1_1.Wel_ref;
   Output.HC = ref_cycle_reversible_vs_1_1.HC_ref;
   Output.CC = ref_cycle_reversible_vs_1_1.CC_ref;
   Output.CMP_f = control_vs_3.CMP_f;
   Output.HP_mode =control_vs_3.HP_operative_mode;
   Output.HP_target =control_vs_3.HP_target;

  connect(Load_in, Load_in) annotation (Line(points={{-110,72},{-110,72}}, color={0,127,255}));
  connect(Source_out, Source_out) annotation (Line(points={{110,-72},{110,-72}}, color={0,127,255}));
  connect(Load_out, Load_out) annotation (Line(points={{110,74},{110,74}}, color={0,127,255}));
  connect(ref_cycle_reversible_vs_1_1.Wel_ref, Wel_ref) annotation (Line(points={{63.91,14.73},{102,14.73},{102,0},{110,0}}, color={0,0,127}));

  connect(FinCoil.port_a, Source_in) annotation (Line(points={{34,-71},{34,-72},{-110,-72},{-110,-70}}, color={0,127,255}));
  connect(Efficency, Efficency) annotation (Line(points={{110,-40},{110,-40}}, color={0,0,127}));
  connect(PHE.Pow_secondary, division.u1) annotation (Line(points={{59.5,66.7},{72,66.7},{72,45.2},{78.6,45.2}}, color={0,0,127}));
  connect(ref_cycle_reversible_vs_1_1.Wel_ref, division.u2) annotation (Line(points={{63.91,14.73},{72,14.73},{72,36.8},{78.6,36.8}},
                                                                                                                                    color={0,0,127}));
  connect(division.y, Efficency_System) annotation (Line(points={{94.7,41},{96,42},{116,42}}, color={0,0,127}));
  connect(FinCoil.port_a, TsourceIn.port) annotation (Line(points={{34,-71},{34,-72},{18,-72},{18,-54},{10,-54}}, color={0,127,255}));
  connect(TsourceIn.T, ref_cycle_reversible_vs_1_1.SET) annotation (Line(points={{17,-44},{23.96,-44},{23.96,-12.3}}, color={0,0,127}));
  connect(TloadIn.T, ref_cycle_reversible_vs_1_1.LET) annotation (Line(points={{15,42},{24,42},{24,20},{23.96,20},{23.96,18.3}}, color={0,0,127}));
  connect(PHE.port_a, TloadIn.port) annotation (Line(points={{28,73},{-2,73},{-2,32},{8,32}}, color={0,127,255}));
  connect(CMP_reversible.CC_Wel, ref_cycle_reversible_vs_1_1.CC_Wel) annotation (Line(points={{-22.31,0.27},{24,0.27},{24,0},{24.13,0},{24.13,-0.57}},
                                                                                                                                                   color={0,0,127}));
  connect(CMP_reversible.HP_operative_status_out, ref_cycle_reversible_vs_1_1.HP_operatve_status) annotation (Line(points={{-22.31,5.47},{24,5.47},{24,6.4},{23.96,6.4}},
                                                                                                                                                                 color={255,127,0}));
  connect(ref_cycle_reversible_vs_1_1.HP_efficency, Efficency) annotation (Line(points={{63.91,-8.05},{63.91,-40},{110,-40}},
                                                                                                                            color={0,0,127}));
  connect(ref_cycle_reversible_vs_1_1.HE1_output, PHE.HE_input) annotation (Line(points={{43.17,22.21},{43,22.21},{43,56.2}},
                                                                                                                           color={0,0,127}));
  connect(PHE.RefT_filter, CMP_reversible.Tref_1) annotation (Line(points={{26.5,67},{26.5,64},{-37,64},{-37,17.82}}, color={0,0,127}));
  connect(FinCoil.RefT, CMP_reversible.Tref_2) annotation (Line(points={{32.5,-63.5},{-36.87,-63.5},{-36.87,-11.69}}, color={0,0,127}));
  connect(ref_cycle_reversible_vs_1_1.HE2_output, FinCoil.HE_input) annotation (Line(points={{43,-16.38},{43.75,-24},{43.75,-54.35}}, color={0,0,127}));
  connect(ref_cycle_reversible_vs_1_1.T_ref_1, PHE.RefT_filter) annotation (Line(points={{23.96,13.2},{-18,13.2},{-18,64},{26.5,64},{26.5,67}},
                                                                                                                                              color={0,0,127}));
  connect(ref_cycle_reversible_vs_1_1.T_ref_2, FinCoil.RefT) annotation (Line(points={{23.96,-7.2},{22,-7.2},{22,-12},{-18,-12},{-18,-63.5},{32.5,-63.5}},
                                                                                                                                         color={0,0,127}));
  connect(control_vs_3.HP_operative_status, CMP_reversible.HP_operative_status) annotation (Line(points={{-73,2},{-52,2},{-52,4},{-51.69,4},{-51.69,5.47}}, color={255,127,0}));
  connect(control_vs_3.CMP_f, CMP_reversible.CMP_f) annotation (Line(points={{-73,-2.2},{-73,0.27},{-51.69,0.27}},   color={0,0,127}));
  connect(control_vs_3.Tmeas, Tmeas1) annotation (Line(points={{-94.8,0},{-124,0}}, color={0,0,127}));
  connect(control_vs_3.HP_operative_status, PHE.HP_operative_status) annotation (Line(points={{-73,2},{-74,2},{-74,84.85},{26.35,84.85}}, color={255,127,0}));
  connect(control_vs_3.HP_operative_status, FinCoil.HP_operative_status) annotation (Line(points={{-73,2},{-74,2},{-74,-82.85},{32.35,-82.85}}, color={255,127,0}));
  connect(Load_in, PHE.port_a) annotation (Line(points={{-110,72},{-2,72},{-2,73},{28,73}}, color={0,127,255}));
  connect(PHE.port_b, TloadOut.port_a) annotation (Line(points={{58,73},{60,74},{76,74}}, color={0,127,255}));
  connect(TloadOut.port_b, Load_out) annotation (Line(points={{96,74},{110,74}}, color={0,127,255}));
  connect(FinCoil.port_b, TsourceOut.port_a) annotation (Line(points={{64,-71},{64,-72},{72,-72}}, color={0,127,255}));
  connect(TsourceOut.port_b, Source_out) annotation (Line(points={{92,-72},{110,-72}}, color={0,127,255}));
  annotation (Icon(graphics={
        Rectangle(
          extent={{-80,80},{80,-80}},
          lineColor={0,0,0},
          fillColor={255,255,255},
          fillPattern=FillPattern.Solid,
          lineThickness=1),
        Bitmap(extent={{-84,-78},{84,76}},
          imageSource="",
          fileName="modelica://HeatPumpModel/../Incons/Copia di HP Cooling.png"),
        Text(
          extent={{-52,-62},{54,-90}},
          textColor={0,0,0},
          textString="Reversible HP
")}), experiment(
      StartTime=425100,
      StopTime=436320,
      Interval=60,
      __Dymola_Algorithm="Radau"));
end Reversible_HP_vs_3;
