within HeatPumpModel.Components.Heating;
model HeatPump_vs_11_test_clean "Deleted control on frrquency of compressors because the esperimental one is used for the model validation"

   //---------------Components---------------------------------------------------------------------------------------------------------------------------------------------------------------------

  Ref_cycle_vs_9_clean ref_cycle_vs_9_clean(
    fileName=fileName,
    SH=SH,
    SBC=SBC,
    redeclare package Medium = Medium,
    F=F,
    PP_eva=PP_eva,
    PP_cond=PP_cond) annotation (Placement(transformation(extent={{26,-20},{60,14}})));
  Condenser_vs_3_clean Condenser(
    redeclare package Medium = cond_medium,
    m_flow_nominal=m_flow_cond_nominal,
    dp_nominal=dp_cond_nominal,
    m_ref_nom=m_ref_nom,
    UA_nom=UA_nom_cond,
    fileName=fileName_cond,
    UA_value_cond=UA_value_cond,
    Tau_cost_cond=Tau_cost_cond,
    V=V_cond) annotation (Placement(transformation(extent={{28,54},{58,84}})));
  Evaporator_vs_2_clean Evaporator(
    redeclare package Medium = eva_medium,
    m_flow_nominal=m_flow_eva_nominal,
    dp_nominal=dp_eva_nominal,
    UA_nom=UA_nom_eva,
    UA_value_eva=UA_value_eva,
    Tau_cost_eva=Tau_cost_eva,
    V=V_eva) annotation (Placement(transformation(extent={{34,-58},{64,-88}})));

  CMP_poly_vs_8_clean CMP_8_clean(fileName=fileName, CMP_type=CMP_type) annotation (Placement(transformation(extent={{-56,-18},{-16,12}})));
  Dew_T_calculation DewT(redeclare package Medium = Medium) annotation (Placement(transformation(
        extent={{8,-8},{-8,8}},
        rotation=-90,
        origin={-36,-46})));
  Modelica.Fluid.Sensors.Temperature SET(redeclare package Medium = eva_medium) annotation (Placement(transformation(extent={{0,-54},{20,-34}})));
  Modelica.Fluid.Sensors.Temperature LET(redeclare package Medium = cond_medium) annotation (Placement(transformation(extent={{-2,32},{18,52}})));

  //---------------Interfaces blocks---------------------------------------------------------------------------------------------------------------------------------------------------------------

  Modelica.Fluid.Interfaces.FluidPort_a Load_in(redeclare package Medium = cond_medium) "Fluid connector a (positive design flow direction is from port_a to port_b)" annotation (Placement(transformation(extent={{-120,62},
            {-100,82}}),                                                                                                                                                                                                        iconTransformation(extent={{-120,62},
            {-100,82}})));
  Modelica.Fluid.Interfaces.FluidPort_b Load_out(redeclare package Medium = cond_medium) "Fluid connector b (positive design flow direction is from port_a to port_b)" annotation (Placement(transformation(extent={{100,60},
            {120,80}}),                                                                                                                                                                                                        iconTransformation(extent={{100,60},
            {120,80}})));
  Modelica.Fluid.Interfaces.FluidPort_a Source_in(redeclare package Medium = eva_medium) "Fluid connector a (positive design flow direction is from port_a to port_b)" annotation (Placement(transformation(extent={{-120,
            -80},{-100,-60}}),                                                                                                                                                                                                        iconTransformation(extent={{-120,
            -80},{-100,-60}})));
  Modelica.Fluid.Interfaces.FluidPort_b Source_out(redeclare package Medium = eva_medium) "Fluid connector b (positive design flow direction is from port_a to port_b)" annotation (Placement(transformation(extent={{100,-82},
            {120,-62}}),                                                                                                                                                                                                        iconTransformation(extent={{100,-82},
            {120,-62}})));
  Modelica.Blocks.Interfaces.RealOutput Wel_ref "heating capacity calculated with refrigerant cycle" annotation (Placement(transformation(extent={{100,14},{120,34}}), iconTransformation(extent={{100,14},{120,34}})));
  Modelica.Blocks.Interfaces.RealOutput COP "Coefficient of performance" annotation (Placement(transformation(extent={{100,-24},{120,-4}}), iconTransformation(extent={{100,-24},{120,-4}})));
  Modelica.Blocks.Math.Division division annotation (Placement(transformation(extent={{80,34},{94,48}})));
  Modelica.Blocks.Interfaces.RealOutput COP_system "Coefficient of performance" annotation (Placement(transformation(extent={{106,32},{126,52}}), iconTransformation(extent={{100,-58},{120,-38}})));
  Modelica.Blocks.Sources.IntegerConstant integerConstant(k=1) annotation (Placement(transformation(extent={{-82,-24},{-72,-14}})));
  Modelica.Blocks.Interfaces.RealInput CMP_f1 "Compressor frequency / speed " annotation (Placement(transformation(extent={{-114,-6},{-94,14}}), iconTransformation(extent={{-114,-6},{-94,14}})));

  //---------------Medium Replaceble Packages-----------------------------------------------------------------------------------------------------------------------------------------------------

  replaceable package Medium = ExternalMedia.Media.CoolPropMedium (mediumName="R410a", substanceNames={"R410a"}) annotation (choices(
      choice(redeclare package Medium = ExternalMedia.Media.CoolPropMedium (mediumName="R290", substanceNames={"R290"}) "R290"),
      choice(redeclare package Medium = ExternalMedia.Media.CoolPropMedium (mediumName="R32", substanceNames={"R32"}) "R32"),
      choice(redeclare package Medium = ExternalMedia.Media.CoolPropMedium (mediumName="R410A", substanceNames={"R410A"}) "R410A")), Dialog(group="Refrigerant"));
  replaceable package cond_medium = Modelica.Media.Interfaces.PartialMedium annotation (choicesAllMatching=true, Dialog(group="Condenser"));
  replaceable package eva_medium = Modelica.Media.Interfaces.PartialMedium annotation (choicesAllMatching=true, Dialog(group="Evaporator"));

  //-------------Input Parameters Refrigerant Cycle------------------------------------------------------------------------------------------------------------------------------------------------

  parameter Real SH(unit="K") "superheat" annotation (Dialog(group="Refrigerant"));
  parameter Real SBC(unit="K") "subcooling" annotation (Dialog(group="Refrigerant"));

  parameter Real PP_eva(unit="K") = 2 "Evaporator pinch point" annotation (Dialog(group="Evaporator"));

  //-------------Input Parameters CMP-------------------------------------------------------------------------------------------------------------------------------------------------------------

  parameter Real F "Dabiri Correlation parameter" annotation (Dialog(group="CMP"));
  parameter String fileName="Select a compressor model" "File path where polynomial coefficients are stored" annotation (choices(
      choice="C:/Users/benafra10167/Desktop/CMP_polynomial/Fixed_Speed_Danfoss/HRH054U4 polynomials.xlsx",
      choice="C:/Users/benafra10167/Desktop/CMP_polynomial/Variable_Speed_Danfoss/VRJ028-K polynomials.xlsx",
      choice="C:/Users/benafra10167/Desktop/CMP_polynomial/Variable_Speed_Danfoss/VZH028CH polynomials.xlsx",
      choice="C:/Users/benafra10167/Desktop/CMP_polynomial/Variable_Speed_Copeland/XHV0181P-9E9-ED3015A polynomials.xlsx"), Dialog(group="CMP"));
  parameter String CMP_type="Fixed speed" annotation (choices(
      choice="Fixed speed",
      choice="Variable speed 20 coeff",
      choice="Variable speed 30 coeff"), Dialog(group="CMP"));
  parameter Real f_nominal(unit="Hz") "nominal compressor frequency" annotation (Dialog(group="CMP"));

  //-------------Input Parameters Condenser--------------------------------------------------------------------------------------------------------------------------------------------------------

  parameter Modelica.Units.SI.MassFlowRate m_flow_cond_nominal "Nominal mass flow rate" annotation (Dialog(group="Condenser"));
  parameter Modelica.Units.SI.PressureDifference dp_cond_nominal "Pressure difference" annotation (Dialog(group="Condenser"));
  parameter Real PP_cond(unit="K") = 2 "Condenser pinch point" annotation (Dialog(group="Condenser"));
  parameter String fileName_cond="C:/Users\benafra10167/Desktop/HE_polynomial/B8T.xlsx" "File path where polynomial coefficients are stored" annotation (choices(
      choice="C:/Users/benafra10167/Desktop/HE_polynomial/B8T.xlsx",
      choice="C:/Users/benafra10167/Desktop/HE_polynomial/B10T.xlsx",
      choice="C:/Users/benafra10167/Desktop/HE_polynomial/B8LAS.xlsx",
      choice="C:/Users/benafra10167/Desktop/HE_polynomial/B16.xlsx"), Dialog(group="Condenser"));
  parameter Real m_ref_nom(unit="kg/s") "Nominal refrigerant mass flow rate [kg/s]" annotation (Dialog(group="Condenser"));
  parameter Real UA_nom_cond(unit="W/K") "Nominal UA value" annotation (Dialog(group="Condenser"));
  parameter String UA_value_cond="Select how to calculate UA" annotation (choices(choice="Nominal value", choice="Parametric correlation"), Dialog(group="Condenser"));
  parameter Modelica.Units.SI.Volume V_cond "Volume" annotation (Dialog(group="Condenser"));
  parameter Modelica.Units.SI.Time Tau_cost_cond(displayUnit="min") = 900 "Time Constant of Cond Filter" annotation (Dialog(group="Condenser"));

  //-------------Input Parameters Evaporator-------------------------------------------------------------------------------------------------------------------------------------------------------

  parameter Modelica.Units.SI.MassFlowRate m_flow_eva_nominal "Nominal mass flow rate" annotation (Dialog(group="Evaporator"));
  parameter Modelica.Units.SI.PressureDifference dp_eva_nominal "Pressure difference" annotation (Dialog(group="Evaporator"));
  parameter Real UA_nom_eva(unit="W/K") = 1000 "Heat transfer/ area product" annotation (Dialog(group="Evaporator"));
  parameter Modelica.Units.SI.Time Tau_cost_eva(displayUnit="min") = 900 "Time Constant of Eva Filter" annotation (Dialog(group="Evaporator"));
  parameter Modelica.Units.SI.Volume V_eva "Volume" annotation (Dialog(group="Evaporator"));
  parameter String UA_value_eva="Select how to calculate UA" annotation (choices(choice="Nominal value", choice="Parametric correlation"), Dialog(group="Evaporator"));

  // =================EQUATION BLOCK===============================================================================================================================================================

equation
  connect(Load_in, Load_in) annotation (Line(points={{-110,72},{-110,72}}, color={0,127,255}));
  connect(Source_out, Source_out) annotation (Line(points={{110,-72},{110,-72}}, color={0,127,255}));
  connect(Load_out, Load_out) annotation (Line(points={{110,70},{110,70}}, color={0,127,255}));
  connect(ref_cycle_vs_9_clean.Wel_ref, Wel_ref) annotation (Line(points={{63.91,8.73},{100,8.73},{100,24},{110,24}}, color={0,0,127}));

  connect(ref_cycle_vs_9_clean.COP, COP) annotation (Line(points={{63.91,-14.05},{88,-14.05},{88,-14},{110,-14}}, color={0,0,127}));
  connect(Load_in, Condenser.port_a) annotation (Line(points={{-110,72},{-110,69},{28,69}},color={0,127,255}));
  connect(Condenser.port_b, Load_out) annotation (Line(points={{58,69},{110,69},{110,70}},color={0,127,255}));
  connect(Evaporator.port_a, Source_in) annotation (Line(points={{34,-73},{34,-72},{-110,-72},{-110,-70}},color={0,127,255}));
  connect(Evaporator.port_b, Source_out) annotation (Line(points={{64,-73},{64,-70},{110,-70},{110,-72}},color={0,127,255}));
  connect(Condenser.RefT, CMP_8_clean.Tcond) annotation (Line(points={{26.5,63},{-20,63},{-20,64},{-36,64},{-36,15}},
                                                                                                      color={0,0,127}));
  connect(COP, COP) annotation (Line(points={{110,-14},{110,-14}}, color={0,0,127}));
  connect(Condenser.HC_secondary, division.u1) annotation (Line(points={{59.5,62.7},{72,62.7},{72,45.2},{78.6,45.2}}, color={0,0,127}));
  connect(ref_cycle_vs_9_clean.Wel_ref, division.u2) annotation (Line(points={{63.91,8.73},{72,8.73},{72,36.8},{78.6,36.8}}, color={0,0,127}));
  connect(division.y, COP_system) annotation (Line(points={{94.7,41},{96,42},{116,42}}, color={0,0,127}));
  connect(integerConstant.y, CMP_8_clean.Mode) annotation (Line(points={{-71.5,-19},{-71.5,-20},{-68,-20},{-68,-6.15},{-58.6,-6.15}},
                                                                                                              color={255,127,0}));
  connect(CMP_8_clean.CMP_f, CMP_f1) annotation (Line(points={{-58.6,-0.15},{-90,-0.15},{-90,4},{-104,4}}, color={0,0,127}));
  connect(Evaporator.port_a, SET.port) annotation (Line(points={{34,-73},{34,-72},{18,-72},{18,-54},{10,-54}}, color={0,127,255}));
  connect(SET.T, ref_cycle_vs_9_clean.SET) annotation (Line(points={{17,-44},{23.96,-44},{23.96,-18.3}}, color={0,0,127}));
  connect(LET.T, ref_cycle_vs_9_clean.LET) annotation (Line(points={{15,42},{24,42},{24,20},{23.96,20},{23.96,12.3}}, color={0,0,127}));
  connect(Evaporator.RefT, DewT.T_eva_in) annotation (Line(points={{32.5,-65.5},{-36,-65.5},{-36,-55.6}}, color={0,0,127}));
  connect(DewT.T_dew, CMP_8_clean.Teva) annotation (Line(points={{-36,-36.56},{-36,-21}}, color={0,0,127}));
  connect(ref_cycle_vs_9_clean.HC_tot, Condenser.HC_tot) annotation (Line(points={{43.17,16.21},{43,18},{43,52.2}}, color={0,0,127}));
  connect(Evaporator.HeatFlow, ref_cycle_vs_9_clean.CC_ref) annotation (Line(points={{43.75,-57.85},{43.75,-22},{44,-22},{44,-22.38},{43,-22.38}}, color={0,0,127}));
  connect(CMP_8_clean.Mode_Output, ref_cycle_vs_9_clean.OnOff) annotation (Line(points={{-12.8,-6},{22,-6},{22,-6.4},{23.96,-6.4}},      color={255,127,0}));
  connect(Condenser.port_a, LET.port) annotation (Line(points={{28,69},{-2,69},{-2,32},{8,32}}, color={0,127,255}));
  connect(DewT.T_dew, ref_cycle_vs_9_clean.Teva) annotation (Line(points={{-36,-36.56},{-36,-28},{16,-28},{16,-13.2},{23.96,-13.2}}, color={0,0,127}));
  connect(Condenser.RefT, ref_cycle_vs_9_clean.Tcond) annotation (Line(points={{26.5,63},{-20,63},{-20,24},{16,24},{16,7.2},{23.96,7.2}}, color={0,0,127}));
  connect(CMP_8_clean.CC_Wel, ref_cycle_vs_9_clean.CC_Wel) annotation (Line(points={{-12.6,-0.15},{22,-0.15},{22,0.4},{23.96,0.4}}, color={0,0,127}));
  annotation (Icon(graphics={
        Rectangle(
          extent={{-80,80},{80,-80}},
          lineColor={255,0,0},
          fillColor={255,255,255},
          fillPattern=FillPattern.Solid,
          lineThickness=1),
        Bitmap(extent={{-84,-76},{84,78}},
          imageSource=
              "",
          fileName="modelica://HeatPumpModel/../Incons/HP Heating.png"),
        Text(
          extent={{-52,-62},{54,-90}},
          textColor={244,125,35},
          textString="HP Heating Mode
")}), experiment(
      StartTime=425100,
      StopTime=436320,
      Interval=60,
      __Dymola_Algorithm="Radau"));
end HeatPump_vs_11_test_clean;
