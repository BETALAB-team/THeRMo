within HeatPumpModel.Experiments;
model Refrigerant_cycle_test_2 "Test refrigerant cycle with costant input"
  Modelica.Blocks.Sources.RealExpression Tc(y=307.1)
    annotation (Placement(transformation(extent={{-64,18},{-44,38}})));
  Modelica.Blocks.Sources.RealExpression Te(y=262.43)
    annotation (Placement(transformation(extent={{-64,-56},{-44,-36}})));
  Modelica.Blocks.Sources.RealExpression Wel(y=2820.1545)
    annotation (Placement(transformation(extent={{-64,-12},{-44,8}})));
  Modelica.Blocks.Sources.RealExpression HC(y=5)
    annotation (Placement(transformation(extent={{-64,4},{-44,24}})));
  Modelica.Blocks.Sources.RealExpression CC(y=8703.572)
    annotation (Placement(transformation(extent={{-64,-40},{-44,-20}})));
  Modelica.Blocks.Sources.RealExpression m_ref(y=0.048143364)
    annotation (Placement(transformation(extent={{-64,-26},{-44,-6}})));
  Components.Ref_cycle_vs_2 ref_cycle_vs_2
    annotation (Placement(transformation(extent={{-4,-32},{40,12}})));
equation
  connect(Tc.y, ref_cycle_vs_2.Tcond) annotation (Line(points={{-43,28},{-14,28},
          {-14,9.36},{-6.64,9.36}}, color={0,0,127}));
  connect(HC.y, ref_cycle_vs_2.HC) annotation (Line(points={{-43,14},{-16,14},{
          -16,1.88},{-6.64,1.88}}, color={0,0,127}));
  connect(Wel.y, ref_cycle_vs_2.Wel) annotation (Line(points={{-43,-2},{-14,-2},
          {-14,-4.28},{-6.64,-4.28}}, color={0,0,127}));
  connect(m_ref.y, ref_cycle_vs_2.m_ref) annotation (Line(points={{-43,-16},{
          -14,-16},{-14,-14.4},{-6.64,-14.4}}, color={0,0,127}));
  connect(CC.y, ref_cycle_vs_2.CC) annotation (Line(points={{-43,-30},{-16,-30},
          {-16,-21},{-6.64,-21}}, color={0,0,127}));
  connect(Te.y, ref_cycle_vs_2.Teva) annotation (Line(points={{-43,-46},{-14,
          -46},{-14,-28.04},{-6.64,-28.04}}, color={0,0,127}));
  annotation (Icon(coordinateSystem(preserveAspectRatio=false)), Diagram(
        coordinateSystem(preserveAspectRatio=false)));
end Refrigerant_cycle_test_2;
