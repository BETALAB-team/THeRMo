within HeatPumpModel.Experiments;
model CMP_ref_test
  Components.CMP_ref_cycle_1 cMP_ref_cycle_1(redeclare package Medium =
        ExternalMedia.Media.CoolPropMedium (mediumName="R410A", substanceNames=
            {"R410A"}) "R410A")
    annotation (Placement(transformation(extent={{0,-16},{26,10}})));
  Modelica.Blocks.Sources.RealExpression Tc(y=293)
    annotation (Placement(transformation(extent={{-64,18},{-44,38}})));
  Modelica.Blocks.Sources.RealExpression Te(y=283)
    annotation (Placement(transformation(extent={{-64,2},{-44,22}})));
  Modelica.Blocks.Sources.RealExpression Pel(y=1700)
    annotation (Placement(transformation(extent={{-64,-16},{-44,4}})));
  Modelica.Blocks.Sources.RealExpression HC(y=5)
    annotation (Placement(transformation(extent={{-64,-30},{-44,-10}})));
  Modelica.Blocks.Sources.RealExpression CC(y=5000)
    annotation (Placement(transformation(extent={{-64,-48},{-44,-28}})));
equation
  connect(Tc.y, cMP_ref_cycle_1.Tcond) annotation (Line(points={{-43,28},{-10,
          28},{-10,7.92},{-1.56,7.92}},
                                 color={0,0,127}));
  connect(Te.y, cMP_ref_cycle_1.Teva) annotation (Line(points={{-43,12},{-12,12},
          {-12,3.76},{-1.56,3.76}},
                               color={0,0,127}));
  connect(Pel.y,cMP_ref_cycle_1.Wel)  annotation (Line(points={{-43,-6},{-12,-6},
          {-12,-0.4},{-1.56,-0.4}},
                               color={0,0,127}));
  connect(HC.y, cMP_ref_cycle_1.HC) annotation (Line(points={{-43,-20},{-12,-20},
          {-12,-4.82},{-1.56,-4.82}},
                                 color={0,0,127}));
  connect(CC.y, cMP_ref_cycle_1.CC) annotation (Line(points={{-43,-38},{-10,-38},
          {-10,-9.24},{-1.56,-9.24}},
                                 color={0,0,127}));
  annotation (Icon(coordinateSystem(preserveAspectRatio=false)), Diagram(
        coordinateSystem(preserveAspectRatio=false)));
end CMP_ref_test;
